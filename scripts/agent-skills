#!/usr/bin/env bash

set -u
set -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(git -C "$script_dir/.." rev-parse --show-toplevel 2>/dev/null)" || {
  echo "error: scripts/agent-skills must run from a Git worktree" >&2
  exit 1
}
config_file="$repo_root/agents/skills.conf"

if [[ ! -f "$config_file" ]]; then
  echo "error: missing configuration: $config_file" >&2
  exit 1
fi

# shellcheck source=../agents/skills.conf
source "$config_file"

read -r -a target_agents <<< "$SKILLS_TARGET_AGENTS"
read -r -a matt_skills <<< "$MATT_SKILLS"
read -r -a here_now_skills <<< "$HERE_NOW_SKILLS"
read -r -a local_skills <<< "$LOCAL_SKILLS"
read -r -a local_fork_skills <<< "$LOCAL_FORK_SKILLS"
read -r -a codex_only_skills <<< "$CODEX_ONLY_SKILLS"
read -r -a expected_executables <<< "$EXPECTED_EXECUTABLES"

third_party_skills=("${matt_skills[@]}" "${here_now_skills[@]}")
tracked_skills=(
  "${local_skills[@]}"
  "${local_fork_skills[@]}"
  "${third_party_skills[@]}"
)

package_root="$repo_root/$SKILLS_PACKAGE_ROOT"
tracked_root="$package_root/$TRACKED_SKILLS_ROOT"
claude_link_root="$package_root/$CLAUDE_LINK_ROOT"
project_lock="$package_root/skills-lock.json"
registry_file="$package_root/SKILLS_REGISTRY.md"
third_party_file="$package_root/THIRD_PARTY.md"
agents_runtime="$HOME/.agents/skills"
claude_runtime="$HOME/.claude/skills"
codex_runtime="${CODEX_HOME:-$HOME/.codex}/skills"

contains_name() {
  local needle="$1"
  shift
  local candidate
  for candidate in "$@"; do
    [[ "$candidate" == "$needle" ]] && return 0
  done
  return 1
}

is_codex_only() {
  contains_name "$1" "${codex_only_skills[@]}"
}

source_for_skill() {
  local skill="$1"
  if contains_name "$skill" "${matt_skills[@]}"; then
    printf '%s\n' "$MATT_SOURCE"
    return 0
  fi
  if contains_name "$skill" "${here_now_skills[@]}"; then
    printf '%s\n' "$HERE_NOW_SOURCE"
    return 0
  fi
  return 1
}

frontmatter_field() {
  local file="$1"
  local field="$2"
  awk -v field="$field" '
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter && index($0, field ":") == 1 {
      sub("^[^:]+:[[:space:]]*", "")
      print
      exit
    }
  ' "$file"
}

strip_quotes() {
  local value="$1"
  value="${value#\"}"
  value="${value%\"}"
  value="${value#\'}"
  value="${value%\'}"
  printf '%s\n' "$value"
}

tree_hash() {
  local directory="$1"
  (
    cd "$directory" || exit 1
    find . -type f -print |
      LC_ALL=C sort -f |
      while IFS= read -r file; do
        printf '%s' "${file#./}"
        command cat "$file"
      done
  ) | shasum -a 256 | awk '{ print $1 }'
}

lock_field_for() {
  local skill="$1"
  local field="$2"
  awk -v skill="$skill" -v field="$field" '
    $0 ~ "^    \"" skill "\": \\{" { in_skill = 1; next }
    in_skill && $0 ~ "^    \"[^\"]+\": \\{" { exit }
    in_skill && $0 ~ "\"" field "\":" {
      sub("^.*: \"", "")
      sub("\".*$", "")
      print
      exit
    }
  ' "$project_lock"
}

validate_config() {
  local failures=0
  local name
  local duplicates

  [[ "$SKILLS_CLI_SPEC" == "skills@latest" ]] || {
    echo "invalid: SKILLS_CLI_SPEC must be skills@latest"
    failures=$((failures + 1))
  }
  [[ "$SKILLS_PACKAGE_ROOT" == "agents" ]] || {
    echo "invalid: SKILLS_PACKAGE_ROOT must be agents"
    failures=$((failures + 1))
  }
  [[ "$TRACKED_SKILLS_ROOT" == ".agents/skills" ]] || {
    echo "invalid: TRACKED_SKILLS_ROOT must be .agents/skills"
    failures=$((failures + 1))
  }
  [[ "$CLAUDE_LINK_ROOT" == ".claude/skills" ]] || {
    echo "invalid: CLAUDE_LINK_ROOT must be .claude/skills"
    failures=$((failures + 1))
  }
  [[ "$STOW_MODE" == "--no-folding" ]] || {
    echo "invalid: STOW_MODE must be --no-folding"
    failures=$((failures + 1))
  }
  [[ "$GENERATED_RUNTIME_PATTERN" == "framer-project-*" ]] || {
    echo "invalid: GENERATED_RUNTIME_PATTERN must be framer-project-*"
    failures=$((failures + 1))
  }
  contains_name codex "${target_agents[@]}" || {
    echo "invalid: codex is not a configured installer target"
    failures=$((failures + 1))
  }
  contains_name claude-code "${target_agents[@]}" || {
    echo "invalid: claude-code is not a configured installer target"
    failures=$((failures + 1))
  }

  duplicates="$(
    printf '%s\n' "${tracked_skills[@]}" |
      LC_ALL=C sort |
      uniq -d
  )"
  if [[ -n "$duplicates" ]]; then
    echo "invalid: skills appear in more than one ownership class:"
    printf '%s\n' "$duplicates"
    failures=$((failures + 1))
  fi

  for name in "${codex_only_skills[@]}"; do
    contains_name "$name" "${local_skills[@]}" "${local_fork_skills[@]}" || {
      echo "invalid: Codex-only skill is not locally owned: $name"
      failures=$((failures + 1))
    }
  done

  return "$failures"
}

validate_relative_references() {
  local root="$1"
  local failures=0
  local markdown
  local match
  local target
  local candidate

  while IFS= read -r markdown; do
    while IFS= read -r match; do
      target="${match#*](}"
      target="${target%)}"
      if [[ "$target" == \<*\> ]]; then
        target="${target#<}"
        target="${target%>}"
      else
        target="${target%%[[:space:]]*}"
      fi
      target="${target%%#*}"
      target="${target%%\\?*}"
      case "$target" in
        ""|\#*|/*|\$*|[a-zA-Z][a-zA-Z0-9+.-]*:*)
          continue
          ;;
      esac
      candidate="$(dirname "$markdown")/$target"
      if [[ ! -e "$candidate" && ! -L "$candidate" ]]; then
        echo "invalid: broken Markdown reference: $markdown -> $target"
        failures=$((failures + 1))
      fi
    done < <(
      awk '
        /^```/ || /^~~~/ { fenced = !fenced; next }
        !fenced { print }
      ' "$markdown" |
        grep -Eo '!?\[[^]]*\]\([^)]*\)' 2>/dev/null || true
    )
  done < <(find "$root" -type f -name '*.md' -print | LC_ALL=C sort)

  return "$failures"
}

validate_skills() {
  local failures=0
  local name
  local path
  local skill_file
  local declared_name
  local description
  local actual_names
  local expected_names
  local declared_names

  [[ -d "$tracked_root" ]] || {
    echo "invalid: missing tracked skill root: $tracked_root"
    return 1
  }

  actual_names="$(
    find "$tracked_root" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; |
      LC_ALL=C sort
  )"
  expected_names="$(printf '%s\n' "${tracked_skills[@]}" | LC_ALL=C sort)"
  if [[ "$actual_names" != "$expected_names" ]]; then
    echo "invalid: configured and present tracked skill directories differ"
    echo "configured:"
    printf '%s\n' "$expected_names"
    echo "present:"
    printf '%s\n' "$actual_names"
    failures=$((failures + 1))
  fi

  declared_names="$(
    for name in "${tracked_skills[@]}"; do
      skill_file="$tracked_root/$name/SKILL.md"
      [[ -f "$skill_file" ]] || continue
      strip_quotes "$(frontmatter_field "$skill_file" name)"
    done |
      LC_ALL=C sort
  )"
  if [[ -n "$(printf '%s\n' "$declared_names" | uniq -d)" ]]; then
    echo "invalid: duplicate frontmatter names:"
    printf '%s\n' "$declared_names" | uniq -d
    failures=$((failures + 1))
  fi

  for name in "${tracked_skills[@]}"; do
    path="$tracked_root/$name"
    skill_file="$path/SKILL.md"
    if [[ ! -f "$skill_file" ]]; then
      echo "invalid: missing SKILL.md: $path"
      failures=$((failures + 1))
      continue
    fi
    declared_name="$(strip_quotes "$(frontmatter_field "$skill_file" name)")"
    description="$(frontmatter_field "$skill_file" description)"
    if [[ "$declared_name" != "$name" ]]; then
      echo "invalid: $skill_file declares name '$declared_name', expected '$name'"
      failures=$((failures + 1))
    fi
    if [[ -z "$description" ]]; then
      echo "invalid: missing or empty description: $skill_file"
      failures=$((failures + 1))
    fi
  done

  validate_relative_references "$tracked_root" || failures=$((failures + 1))
  return "$failures"
}

validate_executables() {
  local failures=0
  local relative
  for relative in "${expected_executables[@]}"; do
    if [[ ! -f "$package_root/$relative" || ! -x "$package_root/$relative" ]]; then
      echo "invalid: expected executable mode is missing: $package_root/$relative"
      failures=$((failures + 1))
    fi
  done
  return "$failures"
}

validate_claude_links() {
  local failures=0
  local name
  local link
  local expected_target
  local expected_names
  local actual_names

  [[ -d "$claude_link_root" ]] || {
    echo "invalid: missing tracked Claude link root: $claude_link_root"
    return 1
  }

  expected_names="$(
    for name in "${tracked_skills[@]}"; do
      is_codex_only "$name" || printf '%s\n' "$name"
    done |
      LC_ALL=C sort
  )"
  actual_names="$(
    find "$claude_link_root" -mindepth 1 -maxdepth 1 -type l -exec basename {} \; |
      LC_ALL=C sort
  )"
  if [[ "$actual_names" != "$expected_names" ]]; then
    echo "invalid: configured and present tracked Claude links differ"
    failures=$((failures + 1))
  fi

  for name in "${tracked_skills[@]}"; do
    link="$claude_link_root/$name"
    if is_codex_only "$name"; then
      if [[ -e "$link" || -L "$link" ]]; then
        echo "invalid: Codex-only skill has a tracked Claude link: $link"
        failures=$((failures + 1))
      fi
      continue
    fi
    expected_target="../../.agents/skills/$name"
    if [[ ! -L "$link" ]]; then
      echo "invalid: missing tracked Claude symlink: $link"
      failures=$((failures + 1))
    elif [[ "$(readlink "$link")" != "$expected_target" ]]; then
      echo "invalid: wrong tracked Claude target: $link -> $(readlink "$link")"
      failures=$((failures + 1))
    elif [[ "$(realpath "$link" 2>/dev/null || true)" != "$(realpath "$tracked_root/$name")" ]]; then
      echo "invalid: tracked Claude link does not resolve to canonical skill: $link"
      failures=$((failures + 1))
    fi
  done
  return "$failures"
}

validate_private_exclusions() {
  local failures=0
  local leaked

  leaked="$(
    find "$package_root" \
      \( -name "$GENERATED_RUNTIME_PATTERN" -o -name '.DS_Store' -o -name '*.db' \
      -o -name '*.sqlite' -o -name '*.sqlite3' -o -name '*.log' -o -name '.env' \) \
      -print
  )"
  if [[ -n "$leaked" ]]; then
    echo "invalid: generated or private runtime content exists in the agents package:"
    printf '%s\n' "$leaked"
    failures=$((failures + 1))
  fi
  return "$failures"
}

validate_registry() {
  local failures=0
  local name
  local count

  [[ -f "$registry_file" ]] || {
    echo "invalid: missing registry: $registry_file"
    return 1
  }
  for name in "${tracked_skills[@]}"; do
    count="$(grep -E -c "^\\| \`$name\` \\|" "$registry_file" || true)"
    if [[ "$count" -ne 1 ]]; then
      echo "invalid: registry must contain exactly one row for $name"
      failures=$((failures + 1))
    fi
  done
  return "$failures"
}

validate_project_lock() {
  local failures=0
  local expected_names
  local actual_names
  local name
  local expected_source
  local recorded_source
  local expected_hash
  local recorded_hash

  [[ -f "$project_lock" ]] || {
    echo "invalid: missing project lock: $project_lock"
    return 1
  }
  grep -q '"version": 1' "$project_lock" || {
    echo "invalid: unsupported project lock version"
    failures=$((failures + 1))
  }

  expected_names="$(printf '%s\n' "${third_party_skills[@]}" | LC_ALL=C sort)"
  actual_names="$(
    sed -n 's/^    "\([^"]*\)": {$/\1/p' "$project_lock" |
      LC_ALL=C sort
  )"
  if [[ "$actual_names" != "$expected_names" ]]; then
    echo "invalid: project lock entries do not match the third-party allowlists"
    failures=$((failures + 1))
  fi

  for name in "${third_party_skills[@]}"; do
    expected_source="$(source_for_skill "$name")"
    recorded_source="$(lock_field_for "$name" source)"
    if [[ "$recorded_source" != "$expected_source" ]]; then
      echo "invalid: lock source mismatch for $name: $recorded_source"
      failures=$((failures + 1))
    fi
    expected_hash="$(tree_hash "$tracked_root/$name")"
    recorded_hash="$(lock_field_for "$name" computedHash)"
    if [[ "$recorded_hash" != "$expected_hash" ]]; then
      echo "invalid: lock content hash mismatch for $name"
      failures=$((failures + 1))
    fi
  done
  return "$failures"
}

validate_licenses() {
  local failures=0
  local license
  for license in \
    "$package_root/licenses/mattpocock-skills-LICENSE.txt" \
    "$package_root/licenses/loopy-LICENSE.txt"; do
    if [[ ! -s "$license" ]]; then
      echo "invalid: missing license record: $license"
      failures=$((failures + 1))
    fi
  done
  grep -q 'lacks a top-level' "$third_party_file" &&
    grep -q 'license file' "$third_party_file" || {
    echo "invalid: here-now license caveat is missing from THIRD_PARTY.md"
    failures=$((failures + 1))
  }
  return "$failures"
}

validate_repository() {
  local failures=0
  validate_config || failures=$((failures + 1))
  validate_skills || failures=$((failures + 1))
  validate_executables || failures=$((failures + 1))
  validate_claude_links || failures=$((failures + 1))
  validate_private_exclusions || failures=$((failures + 1))
  validate_registry || failures=$((failures + 1))
  return "$failures"
}

validate_runtime_skill_files() {
  local skill="$1"
  local failures=0
  local source_root="$tracked_root/$skill"
  local runtime_root="$agents_runtime/$skill"
  local source_file
  local relative
  local runtime_file
  local source_real
  local runtime_real

  if [[ ! -d "$runtime_root" || -L "$runtime_root" ]]; then
    echo "invalid: Stow --no-folding requires a real runtime skill directory: $runtime_root"
    return 1
  fi
  while IFS= read -r source_file; do
    relative="${source_file#"$source_root"/}"
    runtime_file="$runtime_root/$relative"
    if [[ ! -L "$runtime_file" || ! -e "$runtime_file" ]]; then
      echo "invalid: missing Stow-managed runtime file link: $runtime_file"
      failures=$((failures + 1))
      continue
    fi
    source_real="$(realpath "$source_file")"
    runtime_real="$(realpath "$runtime_file" 2>/dev/null || true)"
    if [[ "$runtime_real" != "$source_real" ]]; then
      echo "invalid: wrong runtime file target: $runtime_file -> $runtime_real"
      failures=$((failures + 1))
    fi
  done < <(find "$source_root" -type f -print | LC_ALL=C sort)

  return "$failures"
}

validate_runtime() {
  local failures=0
  local name
  local path
  local expected_names
  local actual_names
  local generated
  local -a generated_entries=()

  if [[ ! -d "$agents_runtime" || -L "$agents_runtime" ]]; then
    echo "invalid: $agents_runtime must be a real directory"
    return 1
  fi
  if [[ ! -d "$claude_runtime" || -L "$claude_runtime" ]]; then
    echo "invalid: $claude_runtime must be a real directory"
    return 1
  fi

  for name in "${tracked_skills[@]}"; do
    validate_runtime_skill_files "$name" || failures=$((failures + 1))
    path="$codex_runtime/$name"
    if [[ -e "$path" || -L "$path" ]]; then
      echo "invalid: duplicate approved skill under application-managed Codex state: $path"
      failures=$((failures + 1))
    fi
  done

  for name in "${tracked_skills[@]}"; do
    path="$claude_runtime/$name"
    if is_codex_only "$name"; then
      if [[ -e "$path" || -L "$path" ]]; then
        echo "invalid: Codex-only runtime skill is exposed to Claude: $path"
        failures=$((failures + 1))
      fi
      continue
    fi
    if [[ ! -L "$path" || ! -e "$path" ]]; then
      echo "invalid: missing Claude runtime link: $path"
      failures=$((failures + 1))
    elif [[ "$(realpath "$path")" != "$(realpath "$tracked_root/$name")" ]]; then
      echo "invalid: wrong Claude runtime target: $path"
      failures=$((failures + 1))
    fi
  done

  shopt -s nullglob
  generated_entries=("$agents_runtime"/$GENERATED_RUNTIME_PATTERN)
  shopt -u nullglob
  for generated in "${generated_entries[@]}"; do
    name="$(basename "$generated")"
    if [[ -L "$generated" || ! -d "$generated" ]]; then
      echo "invalid: generated runtime skill must remain a real directory: $generated"
      failures=$((failures + 1))
    fi
    path="$claude_runtime/$name"
    if [[ ! -L "$path" || ! -e "$path" || "$(realpath "$path")" != "$(realpath "$generated")" ]]; then
      echo "invalid: generated Claude runtime link is missing or wrong: $path"
      failures=$((failures + 1))
    fi
  done

  expected_names="$(
    {
      printf '%s\n' "${tracked_skills[@]}"
      for generated in "${generated_entries[@]}"; do basename "$generated"; done
    } |
      LC_ALL=C sort
  )"
  actual_names="$(
    find "$agents_runtime" -mindepth 1 -maxdepth 1 -exec basename {} \; |
      LC_ALL=C sort
  )"
  if [[ "$actual_names" != "$expected_names" ]]; then
    echo "invalid: runtime .agents skill inventory differs from configured plus generated state"
    failures=$((failures + 1))
  fi

  while IFS= read -r path; do
    echo "invalid: broken runtime link: $path -> $(readlink "$path")"
    failures=$((failures + 1))
  done < <(find "$agents_runtime" "$claude_runtime" -type l ! -exec test -e {} \; -print)

  return "$failures"
}

runtime_is_deployed() {
  local probe="$agents_runtime/bug-triage/SKILL.md"
  [[ -L "$probe" && -e "$probe" ]] || return 1
  [[ "$(realpath "$probe")" == "$(realpath "$tracked_root/bug-triage/SKILL.md")" ]]
}

run_status() {
  local failures=0
  echo "== Repository skill package =="
  validate_repository || failures=$((failures + 1))
  echo
  echo "== Deployed runtime =="
  validate_runtime || failures=$((failures + 1))
  echo
  if [[ "$failures" -eq 0 ]]; then
    echo "Agent skill state is healthy."
    return 0
  fi
  echo "Agent skill state has validation failures." >&2
  return 1
}

run_audit() {
  local failures=0
  echo "== Repository validation =="
  validate_repository || failures=$((failures + 1))
  echo
  echo "== Project lock =="
  validate_project_lock || failures=$((failures + 1))
  echo
  echo "== Licenses and provenance =="
  validate_licenses || failures=$((failures + 1))
  grep -q 'Resolved installer version: `1.5.14`' "$third_party_file" || {
    echo "invalid: resolved Phase 2 installer version is not recorded"
    failures=$((failures + 1))
  }
  grep -q '16a2a5cd00b4416f673f4ff38c7971a04dd708e7' "$third_party_file" || {
    echo "invalid: verified Matt revision is not recorded"
    failures=$((failures + 1))
  }
  grep -q 'f6e7ddb92f51bed76ff4dc8f99457c14b83577e6' "$third_party_file" || {
    echo "invalid: verified here-now revision is not recorded"
    failures=$((failures + 1))
  }
  echo
  echo "== Runtime observation =="
  if runtime_is_deployed; then
    validate_runtime || failures=$((failures + 1))
  else
    echo "runtime cutover is pending; repository validation remains read-only"
    if [[ -e "$codex_runtime/staged-change-reviewer" ]]; then
      echo "expected pre-cutover duplicate: $codex_runtime/staged-change-reviewer"
    fi
  fi
  echo
  if [[ "$failures" -eq 0 ]]; then
    echo "Agent skill audit passed."
    return 0
  fi
  echo "Agent skill audit failed." >&2
  return 1
}

run_pre_install() {
  local failures=0
  local status

  echo "== Project-scope pre-install check =="
  validate_repository || failures=$((failures + 1))
  if rg -n -- '--global|SKILLS_SCOPE=.global.|skills@1[.]5[.]14' "$config_file" >/dev/null 2>&1; then
    echo "invalid: configuration contains obsolete global-scope or pinned-CLI state"
    failures=$((failures + 1))
  fi
  if find "$tracked_root" -mindepth 1 -maxdepth 1 -name "$GENERATED_RUNTIME_PATTERN" | grep -q .; then
    echo "invalid: generated Framer state exists inside the package"
    failures=$((failures + 1))
  fi

  status="$(git -C "$repo_root" status --short --untracked-files=all)"
  if [[ -z "$status" ]]; then
    echo "Repository: clean"
  else
    echo "Repository: dirty; review and explicitly acknowledge the listed worktree before installation"
    printf '%s\n' "$status"
  fi

  echo
  echo "Installer working directory: $package_root"
  echo "Scope: project (no --global)"
  echo "Targets: ${target_agents[*]}"
  echo "Backup guidance: preserve ambiguous runtime or vendored state outside the repository first."
  echo
  echo "Matt source: $MATT_SOURCE"
  printf 'Matt selection: %s\n' "${matt_skills[*]}"
  echo "here-now source: $HERE_NOW_SOURCE"
  printf 'here-now selection: %s\n' "${here_now_skills[*]}"
  echo
  echo "Use only from the package directory:"
  echo "  cd \"$package_root\""
  echo "  npx --yes $SKILLS_CLI_SPEC add $MATT_SOURCE --skill ${matt_skills[*]} --agent ${target_agents[*]} --yes"
  echo "  npx --yes $SKILLS_CLI_SPEC add $HERE_NOW_SOURCE --skill ${here_now_skills[*]} --agent ${target_agents[*]} --yes"

  if [[ "$failures" -eq 0 ]]; then
    echo
    echo "Pre-install checks passed. A dirty worktree still requires human review before running npx."
    return 0
  fi
  return 1
}

run_post_install() {
  local failures=0
  local status

  echo "== Installer change report =="
  status="$(git -C "$repo_root" status --short --untracked-files=all)"
  if [[ -n "$status" ]]; then
    printf '%s\n' "$status"
  else
    echo "No worktree changes."
  fi
  echo
  echo "== Added, deleted, and mode changes =="
  git -C "$repo_root" diff --summary
  echo
  echo "== Project lock =="
  validate_project_lock || failures=$((failures + 1))
  echo
  echo "== Source, registry, reference, and leakage checks =="
  validate_repository || failures=$((failures + 1))
  echo
  echo "Review THIRD_PARTY.md, SKILLS_REGISTRY.md, licenses, and every Git diff before commit."

  if [[ "$failures" -eq 0 ]]; then
    echo "Post-install checks passed."
    return 0
  fi
  echo "Post-install checks failed." >&2
  return 1
}

usage() {
  cat <<'USAGE'
Usage: scripts/agent-skills <command>

Read-only commands:
  status       Validate tracked skills, Stow runtime links, and collisions.
  audit        Validate repository contents, lock metadata, licenses, and runtime.
  pre-install  Check and print the safe project-scoped installer workflow.
  post-install Report installer changes and validate the resulting worktree.
USAGE
}

case "${1:-}" in
  status)
    run_status
    ;;
  audit)
    run_audit
    ;;
  pre-install)
    run_pre_install
    ;;
  post-install)
    run_post_install
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
