/agents/.agents/.dotfiles-skills-state
/agents/.agents/plugins/
/agents/.claude/settings.json
/agents/.claude/plugins/
/agents/.claude/projects/
/agents/.claude/session*
/agents/.codex/*
!/agents/.codex/AGENTS.md
